# Optional reverse proxy for TLS termination (mount as /etc/nginx/nginx.conf).
# Place certificates under ./docker/certs/ and enable HTTPS server block.

events {
    worker_connections 1024;
}

http {
    upstream next_web {
        server web:3000;
    }
    upstream nest_backend {
        server backend:4000;
    }

    server {
        listen 80;
        server_name _;
        location /api/ {
            proxy_pass http://nest_backend;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
        location / {
            proxy_pass http://next_web;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }
    }
}
