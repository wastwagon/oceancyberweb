# Generated port map — copy values into your `.env` (Docker Compose reads `.env` automatically).
# Root docker-compose publishes web and backend only (web→3000, backend→4000).
# Postgres/Redis are internal; for host-mapped DB/Redis use docker/docker-compose.dev.yml or docker-compose.override.yml.

FRONTEND_PORT=3020
BACKEND_PORT=4100

# Public URLs (browser + SSR). When using Docker, use host-mapped ports:
# NEXT_PUBLIC_SITE_URL=http://localhost:3020
# NEXT_PUBLIC_API_URL=http://localhost:4100
