# Generated port map ‚Äî copy values into your `.env` (Docker Compose reads `.env` automatically).
# Host ports below map to fixed container ports: web‚Üí3000, api‚Üí4000, postgres‚Üí5432, redis‚Üí6379.

FRONTEND_PORT=3020
BACKEND_PORT=4100
POSTGRES_PORT=5432
REDIS_PORT=6379
CMS_PORT=8055

# Public URLs (browser + SSR). When using Docker, use host-mapped ports:
# NEXT_PUBLIC_SITE_URL=http://localhost:3020
# NEXT_PUBLIC_API_URL=http://localhost:4100
