// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  source    String?
  status    String   @default("new")
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source, createdAt])
  @@index([status, createdAt])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String
  description String
  techStack   String[]
  imageUrl    String?
  liveUrl     String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  details     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder, createdAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String
  role      String
  content   String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  initials  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder, createdAt])
}

/// API auth + wallet / billing (NestJS)
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  role               String   @default("user")
  fullName           String?
  walletBalanceMinor BigInt   @default(0)
  walletCurrency     String   @default("GHS")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  renewals            UserRenewal[]
  paymentTransactions PaymentTransaction[]
  walletLedger        WalletLedger[]
  projects            ClientProject[]

  @@index([email])
}

model ClientProject {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  status           String   @default("planning")
  totalAmountMinor BigInt
  currency         String   @default("GHS")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  milestones ProjectMilestone[]
  invoices   ProjectInvoice[]
  activities ProjectActivity[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ProjectMilestone {
  id          String   @id @default(cuid())
  projectId   String
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  title       String
  orderIndex  Int
  percentage  Int
  amountMinor BigInt
  status      String   @default("locked")
  unlockedAt  DateTime?
  paidAt      DateTime?
  dueAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice ProjectInvoice?

  @@unique([projectId, code])
  @@unique([projectId, orderIndex])
  @@index([projectId, status])
}

model ProjectInvoice {
  id                   String   @id @default(cuid())
  projectId            String
  project              ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId          String?  @unique
  milestone            ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  invoiceNumber        String   @unique
  title                String
  amountMinor          BigInt
  currency             String   @default("GHS")
  status               String   @default("draft")
  dueAt                DateTime?
  issuedAt             DateTime?
  paidAt               DateTime?
  paystackReference    String?  @unique
  paymentTransactionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([projectId, status, createdAt])
}

model ProjectActivity {
  id        String   @id @default(cuid())
  projectId String
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorType String
  actorId   String?
  action    String
  note      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model RenewalPlan {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  interval        String
  amountMinor     BigInt
  currency        String   @default("GHS")
  isActive        Boolean  @default(true)
  gracePeriodDays Int      @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  renewals UserRenewal[]
}

model UserRenewal {
  id                     String    @id @default(cuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                 String
  plan                   RenewalPlan @relation(fields: [planId], references: [id])
  nextRenewalAt          DateTime
  autoRenewUsingWallet   Boolean   @default(true)
  externalRef            String?
  metadata               Json?
  status                 String    @default("active")
  pausedAt               DateTime?
  cancelledAt            DateTime?
  graceEndsAt            DateTime?
  consecutiveFailures    Int       @default(0)
  lastChargeAttemptAt    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId])
  @@index([nextRenewalAt])
}

model PaymentTransaction {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                String
  status              String
  amountMinor         BigInt
  currency            String
  provider            String
  providerReference   String   @unique
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model WalletLedger {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  amountMinor BigInt
  currency    String
  reference   String
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

/// Configurable site navigation (header/startup menus)
model NavigationMenu {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items NavigationMenuItem[]

  @@index([isActive])
}

model NavigationMenuItem {
  id          String   @id @default(cuid())
  menuId      String
  menu        NavigationMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0)
  heading     String
  description String?
  href        String
  metadata    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([menuId, isActive, sortOrder])
}
