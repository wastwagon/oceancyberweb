{
  "name": "oceancyber-web",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "next dev -p ${FRONTEND_PORT:-3020}",
    "build": "npm run build:shared && prisma generate && next build",
    "build:shared": "npm run build --workspace=@oceancyber/shared",
    "build:api": "npm run build --workspace=@oceancyber/api",
    "start": "next start -p ${FRONTEND_PORT:-3020}",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "audit:all": "npm audit --workspaces --include-workspace-root",
    "dev:api": "npm run start:dev --workspace=@oceancyber/api",
    "docker:up": "node scripts/docker-run.cjs up",
    "docker:down": "node scripts/docker-run.cjs down",
    "docker:ps": "node scripts/docker-run.cjs ps",
    "docker:logs": "node scripts/docker-run.cjs logs",
    "postinstall": "npm run build:shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "export:gbp-photos": "node scripts/export-gbp-geo-tagged-images.mjs",
    "embed:site-image-geo": "node scripts/embed-site-image-geo.mjs",
    "import:industry-ui": "node scripts/import-industry-premium-images.mjs",
    "export:industry-social-ads": "node scripts/export-industry-social-ads.mjs",
    "import:industry-stories": "node scripts/import-industry-story-images.mjs",
    "export:industry-stories": "node scripts/export-industry-story-ads.mjs",
    "rename:site-images": "node scripts/rename-site-images-descriptive.mjs",
    "verify:google-places": "node scripts/verify-google-places.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@oceancyber/shared": "file:packages/shared",
    "@prisma/client": "^5.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "jose": "^5.10.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.469.0",
    "next": "^14.2.18",
    "next-seo": "^6.6.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-icons": "^5.6.0",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
