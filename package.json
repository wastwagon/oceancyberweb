{
  "name": "oceancyber-web",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "next dev -p ${FRONTEND_PORT:-3020}",
    "build": "npm run build:shared && prisma generate && next build",
    "build:shared": "npm run build --workspace=@oceancyber/shared",
    "build:api": "npm run build --workspace=@oceancyber/api",
    "start": "next start -p ${FRONTEND_PORT:-3020}",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "audit:all": "npm audit --workspaces --include-workspace-root",
    "dev:api": "npm run start:dev --workspace=@oceancyber/api",
    "docker:up": "node scripts/docker-run.cjs up",
    "docker:down": "node scripts/docker-run.cjs down",
    "docker:ps": "node scripts/docker-run.cjs ps",
    "docker:logs": "node scripts/docker-run.cjs logs",
    "docker:cms": "node scripts/docker-run.cjs cms",
    "docker:cms:db": "bash scripts/ensure-cms-database.sh",
    "postinstall": "npm run build:shared"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@oceancyber/shared": "file:packages/shared",
    "@prisma/client": "^5.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.469.0",
    "next": "^14.2.18",
    "next-seo": "^6.6.0",
    "next-sitemap": "^4.2.3",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
