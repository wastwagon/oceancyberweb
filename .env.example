# =============================================================================
# OceanCyber — copy to `.env` for Docker Compose / Coolify (see COOLIFY.md)
#   cp .env.example .env
# Never commit `.env` with real secrets.
# =============================================================================

# --- Ports (host → container) -----------------------------------------------
# Used by root docker-compose: web and backend. (DB/Redis are not published from root compose.)
FRONTEND_PORT=3020
BACKEND_PORT=4100
# For `docker/docker-compose.dev.yml` and `docker/docker-compose.hotreload.yml` only:
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- PostgreSQL (used by compose + DATABASE_URL interpolation) ------------
# Default superuser matches Docker/Coolify tooling (role "postgres" exists).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=oceancyber123
POSTGRES_DB=oceancyber

# --- Public URLs (browser). Local Docker defaults --------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3020
NEXT_PUBLIC_API_URL=http://localhost:4100

# Coolify / production: use your real HTTPS URLs, then rebuild `web`
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# --- Nest API ----------------------------------------------------------------
CORS_ORIGIN=http://localhost:3020
# Production: must match the site origin (scheme + host, no path)
# CORS_ORIGIN=https://www.yourdomain.com

JWT_SECRET=change-me-generate-a-long-random-string
SESSION_SECRET=change-session-secret-generate-random

# Inside Docker stack, keep default. Only change if you rename the service.
API_INTERNAL_URL=http://backend:4000

# --- Prisma when running Next/Nest on the HOST (not inside Docker) -----------
# Point at localhost with POSTGRES_PORT above.
DATABASE_URL=postgresql://postgres:oceancyber123@localhost:5432/oceancyber?schema=public

# --- On-demand ISR (optional; admin content edits → fresh portfolio/testimonials) -----
# Same random string on both `web` and `backend` when using Docker Compose / Coolify.
# Backend calls POST ${NEXT_REVALIDATE_URL}/api/revalidate with Bearer REVALIDATE_SECRET.
# REVALIDATE_SECRET=
# Docker default internal URL (override only if you rename the web service):
# NEXT_REVALIDATE_URL=http://web:3000

# --- Next.js (optional features) ---------------------------------------------
GOOGLE_VERIFICATION_CODE=
NEXT_PUBLIC_GA_ID=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Namecheap API (server-only, never expose in NEXT_PUBLIC_*) -------------
# API access requires your server public IPv4 to be allowlisted in Namecheap.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
# true = sandbox API, false/empty = production API
NAMECHEAP_USE_SANDBOX=true

# Optional defaults for domain registration when no checkout contact is supplied.
NAMECHEAP_DEFAULT_FIRST_NAME=
NAMECHEAP_DEFAULT_LAST_NAME=
NAMECHEAP_DEFAULT_ADDRESS1=
NAMECHEAP_DEFAULT_CITY=
NAMECHEAP_DEFAULT_STATE=
NAMECHEAP_DEFAULT_POSTAL_CODE=
NAMECHEAP_DEFAULT_COUNTRY=GH
NAMECHEAP_DEFAULT_PHONE=
NAMECHEAP_DEFAULT_EMAIL=
NAMECHEAP_DEFAULT_ORGANIZATION=
