# Development image: Debian (glibc) for Next.js SWC + Nest watch. Source mounted at runtime.
FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y openssl ca-certificates curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/shared ./packages/shared
COPY backend/package.json ./backend/
COPY prisma ./prisma

ENV NEXT_TELEMETRY_DISABLED=1

RUN npm ci

COPY docker/scripts/entrypoint-dev.sh /usr/local/bin/entrypoint-dev.sh
RUN chmod +x /usr/local/bin/entrypoint-dev.sh

ENTRYPOINT ["/usr/local/bin/entrypoint-dev.sh"]
CMD ["sh", "-c", "echo 'Override CMD in docker-compose (web or backend).' && sleep infinity"]
